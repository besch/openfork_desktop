{
  "name": "openfork_client",
  "private": true,
  "version": "0.0.1",
  "description": "Openfork Client",
  "author": "Openfork",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && npm run start\"",
    "setup:dev": "node scripts/setup-dev.cjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "generate-installer-images": "node scripts/generate-installer-images.cjs",
    "pack": "electron-builder",
    "prepack": "npm run generate-installer-images",
    "release": "electron-builder --publish=always",
    "prerelease": "npm run generate-installer-images"
  },
  "dependencies": {
    "@effect/core": "^0.0.16",
    "@effect/data": "^0.18.7",
    "@effect/platform": "^0.90.2",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.56.1",
    "@tailwindcss/vite": "^4.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.2.3",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.539.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.1.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/recharts": "^1.8.29",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^37.2.6",
    "electron-builder": "^25.0.2",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.openfork.openfork_client",
    "productName": "Openfork Client",
    "icon": "public/icon.png",
    "artifactName": "${productName}-${os}-${arch}.${ext}",
    "afterPack": "scripts/after-pack.cjs",
    "protocols": [
      {
        "name": "OpenFork Desktop App",
        "schemes": [
          "openfork-desktop-app"
        ]
      }
    ],
    "publish": {
      "provider": "github"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs",
      "src/python-process-manager.cjs",
      "src/schedule-manager.cjs",
      "src/auto-compact-manager.cjs",
      "src/docker-cleanup-manager.cjs",
      "src/settings.cjs",
      "src/wsl-utils.cjs",
      "src/docker-storage.cjs",
      "src/docker-engine.cjs",
      "src/docker-monitor.cjs",
      "src/engine-install.cjs",
      "src/ipc-docker.cjs",
      "src/ipc-deps.cjs",
      "config.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "client",
          "client.exe"
        ]
      },
      {
        "from": "scripts/setup-wsl.ps1",
        "to": "bin/setup-wsl.ps1"
      },
      {
        "from": "scripts/setup-linux.sh",
        "to": "bin/setup-linux.sh"
      },
      {
        "from": "scripts/uninstall-engine.sh",
        "to": "bin/uninstall-engine.sh"
      },
      {
        "from": "scripts/compact-wsl.ps1",
        "to": "scripts/compact-wsl.ps1"
      },
      {
        "from": "scripts/relocate-wsl.ps1",
        "to": "scripts/relocate-wsl.ps1"
      },
      {
        "from": "scripts/uninstall-engine.ps1",
        "to": "bin/uninstall-engine.ps1"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/logo.png",
      "maintainer": "Openfork <openforkvideo@gmail.com>"
    },
    "deb": {
      "afterRemove": "build/postuninstall.sh"
    },
    "appImage": {
      "executableArgs": [
        "--no-sandbox"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": "public/installerSidebar.png",
      "uninstallerSidebar": "public/installerSidebar.png",
      "installerHeader": "public/installerHeader.png",
      "include": "build/installer.nsh"
    }
  }
}
